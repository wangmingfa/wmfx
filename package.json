{
  "name": "wmfx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "bun run --filter @browser/shared build",
    "build:ipc": "bun run --filter @browser/ipc-contract build",
    "build:database": "bun run --filter @wmfx/database build",
    "build:proxy": "bun run --filter @browser/proxy build",
    "build:main": "bun run --filter @browser/main build",
    "build:renderer": "bun run --filter @browser/renderer build",
    "build": "bun run build:shared && bun run build:ipc && bun run build:database && bun run build:proxy && bun run build:renderer && bun run build:main",
    "clean": "bun run scripts/clean.ts",
    "generate-icon": "bun run scripts/generate-icon.ts",
    "dev": "bun run scripts/check-deps.ts && bun run download:cores && bun run scripts/dev.ts",
    "download:cores": "bun scripts/download-cores.ts",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "prepare": "husky",
    "lint": "bun run lint:ts && bun run lint:vue && bun run lint:typecheck",
    "lint:ts": "bun x biome check .",
    "lint:vue": "bun x eslint .",
    "lint:typecheck": "bun run --filter '*' typecheck && bun x tsc --noEmit -p scripts/tsconfig.json",
    "format": "bun x biome format --write . && bun x prettier --write '**/*.vue'",
    "format:vue": "bun x prettier --write '**/*.vue'",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "bun x vitest run",
    "test:e2e": "bun run build && bun x playwright test",
    "typecheck": "bun run --filter '*' typecheck",
    "package": "bun run build && electron-builder",
    "package:linux": "bun run build && electron-builder --linux",
    "package:mac": "bun run build && electron-builder --mac",
    "package:win": "bun run build && electron-builder --win"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@biomejs/biome": "^2.5.3",
    "@electron/rebuild": "^4.2.0",
    "@iconify-json/carbon": "^1.2.24",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/mdi": "^1.2.3",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "@types/node-abi": "^3.0.3",
    "@types/semver": "^7.7.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-parser-vue": "^0.0.1-security",
    "eslint-plugin-format": "^2.0.1",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "node-abi": "^4.33.0",
    "playwright": "^1.61.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.9.5",
    "semver": "^7.8.5",
    "sharp": "^0.35.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.ts": "biome check --write --no-errors-on-unmatched",
    "*.vue": [
      "prettier --write",
      "eslint"
    ]
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^11.0.2"
  }
}
