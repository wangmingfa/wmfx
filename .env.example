# Vue DevTools 扩展本地路径（Chrome 扩展目录，用于 Electron 内 F12 调试 Vue）
#
# 用法：
# 1. 在 Chrome 中安装 Vue DevTools 扩展（或从已安装的 Chrome 扩展目录复制）。
# 2. 找到扩展目录，macOS 默认形如：
#    ~/Library/Application Support/Google/Chrome/Default/Extensions/<扩展ID>/<版本号>_0
#    （扩展 ID 可在 chrome://extensions 页面开启"开发者模式"后看到）。
# 3. 将下方的值改为该目录的绝对路径，例如：
#    VUE_DEVTOOLS_PATH=/Users/你的用户名/Library/Application Support/Google/Chrome/Default/Extensions/fmkadmapgofadopljbjfkapdkoienihi/7.7.2_0
#
# 说明：
# - 留空（或不配置）则不装载扩展，生产环境无影响。
# - 该扩展会为应用内每个 WebContents（标签页、弹窗等）装载，启动后用 F12 即可像浏览器一样调试 Vue 组件。
# - 此文件为示例，请复制为 .env.local 后填入真实路径（.env.local 不提交）。
VUE_DEVTOOLS_PATH=

# Vite 开发服务器端口
VITE_DEV_PORT=24680

# 日志等级（debug / info / warn / error），开发期选择后自动记录，下次启动复用
WMFX_LOG_LEVEL=debug
